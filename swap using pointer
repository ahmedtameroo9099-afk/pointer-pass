#include <stdio.h>
void swap(int *ptrNum1,int *ptrNum2)
{
    int temp;
    temp = *ptrNum1;
    *ptrNum1 = *ptrNum2;
    *ptrNum2 = temp;
}
int main()
{
    int a,b;
    printf("enter two numbers to swap\n");
    printf("enter num 1 : ");
    scanf("%d",&a);
    printf("enter num 2 : ");
    scanf("%d",&b);
    printf("numbers before swap\n%d\n%d\n",a,b);
    swap(&a,&b);
    printf("numbers after swap\n%d\n%d\n",a,b);
}
